{
    "name": "analista-de-pliegos",
    "private": true,
    "version": "1.1.0",
    "type": "module",
    "packageManager": "pnpm@9.15.9",
    "scripts": {
        "dev": "vite",
        "dev:vercel": "vercel dev",
        "build": "tsc && vite build",
        "test": "vitest",
        "test:watch": "vitest",
        "test:run": "vitest --run",
        "test:e2e": "playwright test",
        "typecheck": "tsc --noEmit",
        "lint": "eslint . --ext ts,tsx --report-unused-disable-directives --max-warnings 0",
        "format": "prettier --write \"src/**/*.{ts,tsx}\"",
        "format:check": "prettier --check \"src/**/*.{ts,tsx}\"",
        "preview": "vite preview",
        "benchmark:pliegos": "node --import tsx benchmarks/pliegos/run.ts",
        "verify:integrity": "node --import tsx scripts/verify-integrity.ts",
        "verify:release": "bash ./scripts/verify-ci.sh",
        "prepare": "husky",
        "prepare:skills": "npx skills experimental_install"
    },
    "dependencies": {
        "@fontsource-variable/inter": "^5.2.8",
        "@fontsource-variable/space-grotesk": "^5.2.10",
        "@sentry/react": "^10.65.0",
        "@supabase/supabase-js": "^2.110.2",
        "@vercel/analytics": "^1.6.1",
        "@vercel/speed-insights": "^1.3.1",
        "canvas-confetti": "^1.9.4",
        "clsx": "^2.1.0",
        "exceljs": "^4.4.0",
        "i18next": "^25.7.3",
        "i18next-browser-languagedetector": "^8.2.0",
        "lucide-react": "^1.24.0",
        "motion": "^12.42.2",
        "react": "^18.2.0",
        "react-dom": "^18.2.0",
        "react-i18next": "^16.5.0",
        "react-router-dom": "^7.18.1",
        "recharts": "^3.9.2",
        "sonner": "^2.0.7",
        "tailwind-merge": "^2.2.1",
        "tailwindcss-animate": "^1.0.7",
        "zod": "^3.22.4",
        "zustand": "^5.0.14"
    },
    "devDependencies": {
        "@axe-core/playwright": "4.12.1",
        "@playwright/test": "1.58.2",
        "@testing-library/jest-dom": "^6.9.1",
        "@testing-library/react": "^16.3.0",
        "@types/canvas-confetti": "^1.9.0",
        "@types/node": "^25.0.3",
        "@types/react": "^18.2.56",
        "@types/react-dom": "^18.2.19",
        "@typescript-eslint/eslint-plugin": "^7.0.2",
        "@typescript-eslint/parser": "^7.0.2",
        "@vitejs/plugin-react": "^5.1.2",
        "@vitest/coverage-v8": "^4.1.10",
        "autoprefixer": "^10.5.2",
        "eslint": "^8.56.0",
        "eslint-plugin-react-hooks": "^4.6.0",
        "eslint-plugin-react-refresh": "^0.5.3",
        "husky": "^9.1.7",
        "jsdom": "^27.2.0",
        "lint-staged": "^16.4.0",
        "postcss": "^8.5.17",
        "prettier": "^3.9.5",
        "tailwindcss": "^3.4.1",
        "tsx": "^4.23.0",
        "typescript": "^5.5.4",
        "vite": "^7.3.6",
        "vitest": "^4.1.10"
    },
    "pnpm": {
        "overrides": {
            "picomatch": ">=4.0.4",
            "tmp": ">=0.2.7",
            "ws": ">=8.21.0"
        }
    },
    "lint-staged": {
        "{src,e2e}/**/*.{ts,tsx}": [
            "eslint --max-warnings 0"
        ],
        "*.{ts,tsx,json,css}": [
            "prettier --check"
        ]
    }
}
