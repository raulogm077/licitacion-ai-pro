# =============================================================================
# ANALISTA DE PLIEGOS — Variables de entorno
# =============================================================================
# Copia este archivo como .env.local para desarrollo local.
# NUNCA commitees valores reales a control de versiones.
# =============================================================================

# ─── FRONTEND (Vite — deben comenzar con VITE_) ──────────────────────────────

# Supabase — REQUERIDO
# Dónde encontrarlo: Supabase Dashboard → Settings → API
VITE_SUPABASE_URL=https://tu-proyecto.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Sentry — OPCIONAL (tracking de errores en producción)
# Dónde encontrarlo: sentry.io → Settings → Projects → tu-proyecto → Client Keys (DSN)
# Si está vacío, Sentry se desactiva silenciosamente (solo producción/staging)
VITE_SENTRY_DSN=

# ─── BACKEND (Supabase Edge Functions — configurar como secrets) ─────────────
# Estos NO van en .env. Se configuran con el CLI de Supabase:
#   npx supabase secrets set OPENAI_API_KEY=sk-...
# O en el Dashboard: Supabase → Edge Functions → Secrets

# OpenAI — REQUERIDO para el pipeline de análisis
# Dónde encontrarlo: platform.openai.com → API Keys
# OPENAI_API_KEY=sk-proj-...

# Variables auto-inyectadas por el runtime de Supabase (NO configurar manualmente):
#   SUPABASE_URL          → URL del proyecto (= VITE_SUPABASE_URL sin VITE_)
#   SUPABASE_ANON_KEY     → Clave anónima (= VITE_SUPABASE_ANON_KEY sin VITE_)
#   SUPABASE_SERVICE_ROLE_KEY → Clave de servicio (solo disponible en Edge Functions)

# ─── GITHUB ACTIONS SECRETS (repositorio → Settings → Secrets and variables) ─
# Los siguientes secretos deben estar configurados en GitHub para que el CI/CD funcione:

# Supabase — REQUERIDO para deploy de backend
#   SUPABASE_ACCESS_TOKEN  → supabase.com → Account → Access Tokens
#   SUPABASE_PROJECT_ID    → Supabase Dashboard → Settings → General → Reference ID
#   SUPABASE_DB_PASSWORD   → Supabase Dashboard → Settings → Database → Database password
#   VITE_SUPABASE_URL      → igual que arriba (para build de Vercel en CI)
#   VITE_SUPABASE_ANON_KEY → igual que arriba (para build de Vercel en CI)

# Vercel — REQUERIDO para deploy de frontend
#   VERCEL_TOKEN      → vercel.com → Settings → Tokens
#   VERCEL_ORG_ID     → vercel.com → Settings → General → Team ID (o tu User ID)
#   VERCEL_PROJECT_ID → vercel.com → tu proyecto → Settings → General → Project ID

# ─── CONFIGURACIÓN LOCAL ADICIONAL ───────────────────────────────────────────

# Puedes sobreescribir el entorno de Sentry en local si es necesario
# VITE_SENTRY_ENVIRONMENT=development
